{
  "name": "trpc-tanstack-svelte-query",
  "type": "module",
  "version": "11.17.0",
  "description": "TanStack Svelte Query Integration for tRPC",
  "author": "juliusmarminge",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trpc/trpc.git",
    "directory": "packages/trpc-tanstack-svelte-query"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --preserveWatchOutput --pretty"
  },
  "exports": {
    "./package.json": "./package.json",
    "./TRPCContext.svelte": "./src/TRPCContext.svelte",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "package.json",
    "!**/*.test.*",
    "!**/__tests__"
  ],
  "eslintConfig": {
    "rules": {
      "no-restricted-imports": [
        "error",
        "trpc-tanstack-svelte-query"
      ],
      "@typescript-eslint/prefer-function-type": "off"
    }
  },
  "peerDependencies": {
    "@tanstack/svelte-query": ">=6",
    "@trpc/client": ">=11.17.0",
    "@trpc/server": ">=11.17.0",
    "svelte": ">=5.25.0",
    "typescript": ">=5.7.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tanstack/svelte-query": "^6",
    "@trpc/client": "11.17.0",
    "@trpc/server": "11.17.0",
    "@types/node": "^22.13.5",
    "eslint": "^9.26.0",
    "event-source-polyfill": "^1.0.31",
    "konn": "^0.7.0",
    "svelte": "^5.56.2",
    "tsdown": "0.12.7",
    "typescript": "^5.9.2",
    "vite": "^8.0.16",
    "vitest": "^4.0.18",
    "ws": "^8.0.0",
    "zod": "^4.2.1"
  },
  "publishConfig": {
    "access": "public"
  }
}